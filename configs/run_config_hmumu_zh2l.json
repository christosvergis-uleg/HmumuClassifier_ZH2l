{
  "tree_name": "tree_Hmumu",
  "signal_files": ["data/signal_ZH_training.root"],
  "background_files": [
    "data/DY_training.root",
    "data/VV_training.root",
    "data/top_training.root"
  ],
  "event_id_column": "event",
  "weight_column": "weight",
  "n_folds_outer": 4,
  "random_state": 42,
  "verbose": 1,
  "tuning": {
    "inner_cv": 2,
    "n_iter": 5,
    "scoring": "average_precision"
  },
  "features_final": [
    "Muons_PT_Lead",
    "Muons_PT_Sub",
    "Event_VT_over_HT",
    "dR_mu0_mu1",
    "Jets_jetMultip",
    "Event_MET",
    "Muons_CosThetaStar",
    "Event_MET_Sig",
    "DPHI_MET_DIMU"
  ],
  "feature_plotting": {
    "enabled": true,
    "subdir": "feature_plots",
    "bins": 50,
    "density": false,
    "normalize": true,
    "ncols": 3,
    "atlas_label": {
      "enabled": true,
      "label": "ATLAS - Internal",
      "com_energy": "$\\sqrt{s}=13.6\\ \\mathrm{TeV}$",
      "lumi": "$165\\ \\mathrm{fb}^{-1}$"
    },
    "per_feature": {
      "Muons_PT_Lead": {
        "bins": 60,
        "xlim": [0.0, 250.0],
        "xlabel": "Leading muon $p_{T}$ [GeV]"
      },
      "Muons_PT_Sub": {
        "bins": 60,
        "xlim": [0.0, 200.0],
        "xlabel": "Subleading muon $p_{T}$ [GeV]"
      },
      "Event_MET": {
        "bins": 40,
        "xlim": [100.0, 300.0],
        "xlabel": "$E_{T}^{\\mathrm{miss}}$ [GeV]"
      },
      "Event_MET_Sig": {
        "bins": 80,
        "xlim": [0.0, 40.0],
        "xlabel": "$E_{T}^{\\mathrm{miss}}$ [GeV]"
      },
      "DPHI_MET_DIMU": {
        "bins": 50,
        "xlim": [0.0, 3.2],
        "xlabel": "$\\Delta\\phi(E_{T}^{\\mathrm{miss}}, \\mu\\mu)$"
      },
      "Jets_jetMultip":{
        "bins": 10,
        "xlim": [0, 10],
        "xlabel": "$N_{j}$"
      }

    }
  },
  "base_params": {
    "objective": "binary:logistic",
    "eval_metric": "logloss",
    "tree_method": "hist",
    "n_estimators": 300,
    "n_jobs": 8,
    "scale_pos_weight" : 3000
  },
  "param_distributions": {
    "max_depth": [3, 4, 5],
    "learning_rate": [0.01, 0.03, 0.05],
    "subsample": [0.6, 0.8, 1.0],
    "colsample_bytree": [0.6, 0.8, 1.0],
    "min_child_weight": [1.0, 2.0, 5.0],
    "reg_lambda": [0.5, 1.0, 2.0, 5.0],
    "gamma": [0.0, 0.1, 0.5],
    "n_estimators": [300, 600, 1000]
  },
  "weight_mode": "positive_only"
}
